{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "House-style bar chart — colors from harchaoui.org/warith/colors, rounded corners 10 px.",
  "data": {
    "values": [
      {"category": "Mon", "value": 120},
      {"category": "Tue", "value": 184},
      {"category": "Wed", "value": 152},
      {"category": "Thu", "value": 201},
      {"category": "Fri", "value": 178},
      {"category": "Sat", "value": 93},
      {"category": "Sun", "value": 76}
    ]
  },
  "mark": { "type": "bar", "cornerRadiusEnd": 10, "color": "#007AFF" },
  "encoding": {
    "x": { "field": "category", "type": "nominal", "axis": { "labelAngle": 0, "title": null } },
    "y": { "field": "value", "type": "quantitative", "axis": { "title": null, "grid": false } },
    "tooltip": [
      { "field": "category", "title": "Day" },
      { "field": "value",    "title": "Active users", "format": "," }
    ]
  },
  "width": "container",
  "height": 220,
  "padding": 8,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "labelFont": "Montserrat",
      "titleFont": "Montserrat",
      "labelColor": "#3C3C43",
      "titleColor": "#000000",
      "domain": true,
      "domainColor": "rgba(60,60,67,0.36)",
      "tickColor": "rgba(60,60,67,0.36)",
      "labelFontSize": 12
    },
    "title":  { "font": "Montserrat", "fontWeight": 600, "color": "#000000" },
    "legend": { "labelFont": "Montserrat", "titleFont": "Montserrat" },
    "range": {
      "category": ["#007AFF","#28CD41","#FF9500","#AF52DE","#FF2D55","#FFCC00","#79DBDC","#FF3B30"],
      "diverging": ["#FF3B30","#FFCC00","#28CD41"],
      "heatmap":   ["#CCE4FF","#007AFF"],
      "ramp":      ["#CCE4FF","#007AFF"]
    }
  }
}
